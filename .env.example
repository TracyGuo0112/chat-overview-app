# ─── 数据库连接（两种方式二选一）────────────────────────────────────────────────
#
# 方式 1：单个连接字符串（推荐，Vercel 上只需配这一个变量）
# 从 Neon 控制台 → Connection Details → Pooled connection 复制
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/dbname?sslmode=require
#
# 方式 2：分散变量（本地 .env 兼容方式）
PGHOST=ep-xxx-pooler.ap-southeast-1.aws.neon.tech
PGDATABASE=your_database_name
PGUSER=your_username
PGPASSWORD=your_password
PGSSLMODE=require

# ─── PostHog（可选，不配置时游客访问数不显示）────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
POSTHOG_PROJECT_ID=

# ─── 业务参数（可选，有默认值）───────────────────────────────────────────────
ONLINE_WINDOW_MINUTES=5
LOW_REMAINING_WINDOW_HOURS=48
