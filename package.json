{
  "scripts": {
    "start": "node server.js",
    "dev": "npm run dev:all",
    "dev:all": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node --watch server.js",
    "dev:web": "npm run dev --prefix shadcn-admin-template",
    "build": "npm install --prefix shadcn-admin-template && npm run build --prefix shadcn-admin-template",
    "build:web": "npm run build --prefix shadcn-admin-template",
    "db:apply-indexes": "node scripts/apply-indexes.js",
    "check:regression": "node scripts/regression-check.js",
    "check:perf": "node scripts/perf-check.js"
  },
  "dependencies": {
    "@vercel/functions": "^3.4.3",
    "dotenv": "^17.2.4",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
